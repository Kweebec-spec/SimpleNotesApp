<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainNotesFragment">

    <fragment
        android:id="@+id/mainNotesFragment"
        android:name="com.example.simplenotesapp.fragments_folder.MainNotesFragment"
        android:label="Notes">
        <action
            android:id="@+id/action_mainNotes_to_notificationSettings"
            app:destination="@id/notificationSettingsFragment" />
        <action
            android:id="@+id/action_mainNotes_to_note"
            app:destination="@id/noteFragment" />
        <action
            android:id="@+id/action_mainNotes_to_addTheme"
            app:destination="@id/addThemeFragment" />
    </fragment>

    <fragment
        android:id="@+id/notificationSettingsFragment"
        android:name="com.example.simplenotesapp.fragments_folder.NotificationSettingsFragment"
        android:label="Notification Settings">
        <!-- Add action to navigate back to MainNotesFragment -->
        <action
            android:id="@+id/action_notificationSettings_to_mainNotes"
            app:destination="@id/mainNotesFragment"
            app:popUpTo="@id/mainNotesFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/noteFragment"
        android:name="com.example.simplenotesapp.fragments_folder.NoteFragment"
        android:label="Note">
        <argument
            android:name="noteId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/addThemeFragment"
        android:name="com.example.simplenotesapp.fragments_folder.AddThemeFragment"
        android:label="Add Theme">
        <action
            android:id="@+id/action_addTheme_to_mainNotes"
            app:destination="@id/mainNotesFragment"
            app:popUpTo="@id/mainNotesFragment"
            app:popUpToInclusive="false" />
    </fragment>

</navigation>